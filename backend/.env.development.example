# ResearchOne Backend — Development (local)
NODE_ENV=development
PORT=3001

# Database (local dev)
DATABASE_URL=postgresql://researchone:changeme@localhost:5432/researchone
DB_HOST=localhost
DB_PORT=5432
DB_NAME=researchone
DB_USER=researchone
DB_PASSWORD=changeme

# Redis (local dev)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face Inference API (Research One 2 uncensored red-team models)
HF_TOKEN=

# Security
JWT_SECRET=change_this_to_a_random_secret_min_32_chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Model routing: defaults live in backend/src/config/defaultModels.ts (V1) and
# backend/src/config/researchEnsemblePresets.ts (Research One 2 per objective).
# Optional emergency overrides only — e.g. PLANNER_MODEL=openai/o3

# Embedding
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BATCH_SIZE: chunks sent per generateEmbeddings() call.
# Default 20 keeps total payload safely under 50k estimated tokens.
# The service auto-splits batches if token budget is exceeded regardless.
EMBEDDING_BATCH_SIZE=20

# Ingestion
# MAX_CHUNK_SIZE is in CHARACTERS (not tokens). text-embedding-3-small has an
# 8,191 token per-string limit (~28,000 chars at 3.5 chars/token).
# Keep at or below 6000 chars to stay well under the limit; raise only if
# you need longer context windows and understand the tradeoff.
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=50

# Exports
EXPORTS_DIR=/opt/researchone/exports

# Admin runtime control
ADMIN_RUNTIME_TOKEN=INSECURE_DEV_TOKEN_CHANGE_ME
RUNTIME_RESTART_COMMAND=pm2 restart researchone-api

# Autonomous external research discovery
DISCOVERY_ENABLED=true
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_BASE_URL=https://api.tavily.com/search
SEARCH_PROVIDER_API_KEY=
SEARCH_PROVIDER_BASE_URL=
MAX_EXTERNAL_DISCOVERY_RESULTS=25
MAX_EXTERNAL_INGEST_PER_RUN=10

# Plain-language report pass (OpenRouter slug)
PLAIN_LANGUAGE_SYNTHESIZER_MODEL=anthropic/claude-3.5-haiku
PLAIN_LANGUAGE_SYNTHESIZER_FALLBACK=google/gemini-2.5-flash

# Publish report to GitHub for thenewontology.life Featured Report workflow (optional)
# FEATURED_REPORT_GITHUB_TOKEN=
# FEATURED_REPORT_GITHUB_OWNER=GooseyPrime
# FEATURED_REPORT_GITHUB_REPO=newontology
# FEATURED_REPORT_GITHUB_PATH=content/featured-reports/latest.md
# FEATURED_REPORT_GITHUB_BRANCH=main

# Per-run progress telemetry replay
# Progress events are persisted in research_runs.progress_events by default.

# Atlas disaster-recovery and auto-export controls
# ATLAS_BACKUP_DIR=/opt/researchone/exports-backup
# ATLAS_AUTO_EXPORT_ON_EMBEDDING=false

# Nomic Atlas integration (InTellMe dataset)
# NOMIC_API_KEY=your_nomic_api_key_here
# NOMIC_ATLAS_DATASET_SLUG=intellme
# NOMIC_ATLAS_BASE_URL=https://api-atlas.nomic.ai
# NOMIC_AUTO_UPLOAD_ON_EXPORT=true

# Together.ai fallback provider for HF-routed model ids
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
