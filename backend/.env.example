# ResearchOne Backend
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://researchone:changeme@localhost:5432/researchone
DB_HOST=10.0.101.2
DB_PORT=5432
DB_NAME=researchone
DB_USER=researchone
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://10.0.101.3:6379
REDIS_HOST=10.0.101.3
REDIS_PORT=6379
# Set REDIS_PASSWORD if Redis requirepass is enabled
REDIS_PASSWORD=
REDIS_USERNAME=

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model routing
PLANNER_MODEL=deepseek/deepseek-r1
RETRIEVER_MODEL=deepseek/deepseek-r1
REASONER_MODEL=deepseek/deepseek-r1
SKEPTIC_MODEL=deepseek/deepseek-r1
SYNTHESIZER_MODEL=qwen/qwen-2.5-72b-instruct
VERIFIER_MODEL=deepseek/deepseek-r1
EMBEDDING_MODEL=openai/text-embedding-3-small

# Fallback models (all roles now have fallbacks)
PLANNER_FALLBACK=anthropic/claude-3.5-sonnet
RETRIEVER_FALLBACK=anthropic/claude-3.5-sonnet
REASONER_FALLBACK=anthropic/claude-3.5-sonnet
SKEPTIC_FALLBACK=anthropic/claude-3.5-sonnet
SYNTHESIZER_FALLBACK=qwen/qwen-2.5-72b-instruct
VERIFIER_FALLBACK=anthropic/claude-3.5-sonnet

# Security
JWT_SECRET=change_this_to_a_random_secret_min_32_chars
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Embedding
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Ingestion
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=50

# Exports — canonical path must match nginx /exports alias on Emma runtime VM
EXPORTS_DIR=/opt/researchone/exports

# Admin runtime control
ADMIN_RUNTIME_TOKEN=
RUNTIME_RESTART_COMMAND=pm2 restart ecosystem.config.js

# Autonomous external research discovery
DISCOVERY_ENABLED=true
SEARCH_PROVIDER=generic
SEARCH_PROVIDER_API_KEY=
SEARCH_PROVIDER_BASE_URL=
MAX_EXTERNAL_DISCOVERY_RESULTS=25
MAX_EXTERNAL_INGEST_PER_RUN=10
