# ResearchOne Backend — Production (Emma runtime VM)
NODE_ENV=production
PORT=3001

# Database (Emma Postgres VM)
DATABASE_URL=postgresql://researchone:<postgres-password>@<emma-postgres-vm-host>:5432/researchone
DB_HOST=<emma-postgres-vm-host>
DB_PORT=5432
DB_NAME=researchone
DB_USER=researchone
DB_PASSWORD=<postgres-password>

# Redis (Emma Redis VM)
REDIS_URL=redis://<emma-redis-vm-host>:6379
REDIS_HOST=<emma-redis-vm-host>
REDIS_PORT=6379
# Set only if Redis auth/ACL is enabled
REDIS_PASSWORD=
REDIS_USERNAME=

# OpenRouter (server-side only — never in Vercel)
OPENROUTER_API_KEY=<openrouter-api-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face Inference API (Research One 2 uncensored red-team models)
HF_TOKEN=

# Security (server-side only — never in Vercel)
JWT_SECRET=<min-32-char-random-secret>
# Origins only (scheme + host, no path). Trailing slashes are ignored. Include every Vercel
# preview host you use, or use a pattern-based allowlist in a reverse proxy if needed.
CORS_ORIGINS=https://<your-vercel-project>.vercel.app,https://<your-custom-frontend-domain>
# Multiple origins are comma-separated

# Clerk authentication (backend)
# Get keys from https://dashboard.clerk.com → API keys
# Webhook secret: https://dashboard.clerk.com → Webhooks → Endpoint → Signing Secret
CLERK_PUBLISHABLE_KEY=pk_live_REPLACE
CLERK_SECRET_KEY=sk_live_REPLACE
CLERK_WEBHOOK_SECRET=whsec_REPLACE
# Clerk-based admin allowlist (comma-separated Clerk user IDs).
# Users in this list pass requireAdmin via JWT alone — no static token needed.
# Get your user ID from Clerk dashboard → Users → click user → "User ID" field.
# Example: ADMIN_USER_IDS=user_2abc123,user_2def456
ADMIN_USER_IDS=
# Legacy break-glass / automation token. Optional once ADMIN_USER_IDS is set.
# Used by ops scripts and CI that cannot present a Clerk session.
# Leave blank in normal operation; set only when automation needs admin access.
ADMIN_RUNTIME_TOKEN=

# Model routing: defaults in backend/src/config/defaultModels.ts and researchEnsemblePresets.ts.
# Optional emergency overrides only.

# Embedding
EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BATCH_SIZE: chunks per generateEmbeddings() call. Default 20.
# The service auto-splits if a batch's estimated token payload exceeds 50k.
EMBEDDING_BATCH_SIZE=20

# Ingestion
# MAX_CHUNK_SIZE is in CHARACTERS. Keep ≤6000 to stay under the
# text-embedding-3-small per-string limit (8,191 tokens / ~28,000 chars).
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_FILE_SIZE_MB=50

# Exports — canonical path must match nginx /exports alias on Emma runtime VM
EXPORTS_DIR=/opt/researchone/exports

# Admin runtime control (set ADMIN_RUNTIME_TOKEN in Clerk block above if using break-glass)
RUNTIME_RESTART_COMMAND=pm2 restart researchone-api
# Optional: PM2 log paths for GET /api/admin/runtime/logs (defaults match ecosystem cwd)
# RUNTIME_LOG_OUT=/opt/researchone/backend/logs/pm2-out.log
# RUNTIME_LOG_ERR=/opt/researchone/backend/logs/pm2-error.log

# Autonomous external research discovery
DISCOVERY_ENABLED=true
SEARCH_PROVIDER=tavily
# SEARCH_PROVIDER supports: tavily | generic | brave | cascade
TAVILY_API_KEY=<tavily-api-key>
TAVILY_BASE_URL=https://api.tavily.com/search
# Legacy optional provider inputs (leave blank unless using that provider mode)
SEARCH_PROVIDER_API_KEY=
SEARCH_PROVIDER_BASE_URL=
MAX_EXTERNAL_DISCOVERY_RESULTS=25
MAX_EXTERNAL_INGEST_PER_RUN=10

# Together.ai fallback provider for HF-routed model ids
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
