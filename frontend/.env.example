# Frontend environment variables for Vercel deployment
# Copy this to .env.local for local development

# Emma backend base URL (no trailing slash)
# Example: https://api.yourdomain.com
# Leave blank to use same-origin /api (all-in-one mode)
# Production builds (vite build) require VITE_API_BASE_URL and VITE_SOCKET_URL when deploying the UI separately from the API (e.g. Vercel + Emma).
VITE_API_BASE_URL=

# Emma backend Socket.IO URL
# Example: https://api.yourdomain.com
# Leave blank to use current browser origin
VITE_SOCKET_URL=

# Emma backend exports base URL for Atlas export downloads
# Example: https://api.yourdomain.com
# Leave blank to use same-origin /exports
VITE_EXPORTS_BASE_URL=
